#!/bin/bash

# Valores por defecto
STATUS="private"
DESTINY=""
NAME=""

# Ayuda del script
usage() {
    echo "Error: command usage:"
    echo "creater -n <repo_name> [ -s public|private ] [ -d destiny ]"
    exit 1
}

# Si no hay argumentos, mostrar uso
if [ $# -eq 0 ]; then
    usage
fi

# Parsear argumentos con getopts
while getopts "n:s:d:h" opt; do
    case "$opt" in
        n) NAME="$OPTARG" ;;
        s) STATUS="$OPTARG" ;;
        d) DESTINY="$OPTARG" ;;
        h|*) usage ;;
    esac
done

# Validar que el nombre sea obligatorio
if [ -z "$NAME" ]; then
    echo "Error: Repository name (-n) is required."
    exit 1
fi

# Validar que el status sea correcto (public o private)
if [ "$STATUS" != "public" ] && [ "$STATUS" != "private" ]; then
    echo "Error: Status (-s) must be 'public' or 'private'. Default is private."
    exit 1
fi

# Chequeo básico de que gh existe y está logueado
if ! command -v gh >/dev/null 2>&1; then
    echo "Error: gh CLI no está instalado."
    exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
    echo "Error: no estás autenticado en gh. Corre 'gh auth login'."
    exit 1
fi

# Configurar el target final (si hay destino, se usa 'destino/nombre', si no, solo 'nombre')
if [ -n "$DESTINY" ]; then
    GH_TARGET="$DESTINY/$NAME"
else
    GH_TARGET="$NAME"
fi

echo "🚀 Creando repositorio en GitHub: $GH_TARGET ($STATUS)..."

# 1. Crear el repositorio en GitHub usando la CLI
gh repo create "$GH_TARGET" --"$STATUS" -y

if [ $? -ne 0 ]; then
    echo "Error: Failed to create repository on GitHub."
    exit 1
fi

# 2. Detectar si ya estamos dentro de un repo git (buscando hacia arriba, como git realmente lo hace)
#    En vez de solo mirar '.git' en el directorio actual (lo que falla en subcarpetas)
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    REPO_ROOT="$(git rev-parse --show-toplevel)"
    echo "📦 Ya existe un repositorio git (detectado en $REPO_ROOT)"
    cd "$REPO_ROOT" || { echo "Error: no se pudo entrar a $REPO_ROOT"; exit 1; }
else
    echo "📦 Inicializando repositorio local..."
    git init -b main
fi

# 3. Detectar la rama actual en vez de asumir 'main'
CURRENT_BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null)"
if [ -z "$CURRENT_BRANCH" ]; then
    # repo recién inicializado sin commits todavía, HEAD no apunta a nada resolviable
    CURRENT_BRANCH="main"
fi

# 4. Vincular el remoto (si ya existía, gh a veces lo vincula, por si acaso aseguramos)
REMOTE_URL="https://github.com/${GH_TARGET}.git"
if git remote get-url origin >/dev/null 2>&1; then
    git remote set-url origin "$REMOTE_URL"
else
    git remote add origin "$REMOTE_URL"
fi

# 5. Commitear solo si hace falta (cambios pendientes o cero commits todavía)
HAS_COMMITS=true
git log -1 >/dev/null 2>&1 || HAS_COMMITS=false

if [ -n "$(git status --porcelain)" ] || [ "$HAS_COMMITS" = false ]; then
    echo "💾 Creando commit..."
    git add .
    git commit -m "[INIT]: repository created" --allow-empty
else
    echo "ℹ️ No hay cambios nuevos que commitear."
fi

# 6. El push SIEMPRE se intenta, independientemente de si hubo commit nuevo,
#    porque el remoto puede ser nuevo o distinto y el historial local debe llegar a él.
echo "📤 Subiendo a $CURRENT_BRANCH..."
git push -u origin "$CURRENT_BRANCH"

if [ $? -ne 0 ]; then
    echo "Error: Falló el push a origin/$CURRENT_BRANCH."
    exit 1
fi

echo "✅ ¡Todo listo! Repositorio configurado y sincronizado."